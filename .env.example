# ============================================================
# Music Atlas — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# For Vercel deployment, add these in Project Settings → Environment Variables.
# ============================================================

# ── Frontend (Vite) ──────────────────────────────────────────
# Base URL of the existing Music Atlas backend API
VITE_MUSIC_ATLAS_API_URL=https://api-refactor.vercel.app/

# ── Backend URL (for serverless functions) ───────────────────
# Same backend, but accessed from Node.js serverless functions (no VITE_ prefix)
MUSIC_ATLAS_API_URL=https://api-refactor.vercel.app

# ── JWT ──────────────────────────────────────────────────────
# Must match the secret used by the backend (api-refactor) to sign tokens
JWT_SECRET=

# ── Google OAuth ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Type: Web application
# Redirect URI: https://<your-domain>/api/auth/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Apple Sign-In ────────────────────────────────────────────
# Create at: https://developer.apple.com → Certificates, IDs & Profiles
# Service ID with "Sign in with Apple" enabled
# Return URL: https://<your-domain>/api/auth/apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Contents of the .p8 key file — replace literal newlines with \n
APPLE_PRIVATE_KEY=

# ── Upstash Redis (credit & subscription storage) ───────────
# Create at: https://console.upstash.com → Create Database
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Stripe (payments) ───────────────────────────────────────
# Dashboard: https://dashboard.stripe.com
# Secret key from: Developers → API Keys
STRIPE_SECRET_KEY=

# Price IDs from: Products → Music Atlas → Prices
# Artist tier: $10/month recurring
STRIPE_PRICE_ARTIST=
# Studio tier: $20/month recurring
STRIPE_PRICE_STUDIO=

# Webhook signing secret from: Developers → Webhooks → your endpoint
# Endpoint URL: https://<your-domain>/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated,
#          customer.subscription.deleted, invoice.payment_succeeded,
#          invoice.payment_failed
STRIPE_WEBHOOK_SECRET=
